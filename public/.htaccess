# Browser Caching
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 1 month"
  
  # CRITICAL: Do NOT cache HTML files
  # This ensures users always get the latest index.html which points to the correct JS chunks
  ExpiresByType text/html "access plus 0 seconds"
  
  # Cache assets with hashes (JS/CSS) - safe to cache long-term as filename changes on update
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType video/mp4 "access plus 1 year"
  ExpiresByType video/webm "access plus 1 year"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType font/ttf "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# Forced fresh headers for HTML
<IfModule mod_headers.c>
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires 0
  </FilesMatch>
</IfModule>

# Gzip Compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/plain
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/xml
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE application/xml
  AddOutputFilterByType DEFLATE application/xhtml+xml
  AddOutputFilterByType DEFLATE application/rss+xml
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/x-javascript
</IfModule>

# Disable ETag
<IfModule mod_headers.c>
  Header unset ETag
</IfModule>
# SPA Routing & Redirects
Options -MultiViews
RewriteEngine On
RewriteBase /

# Force HTTPS + remove www (single redirect for speed/SEO)
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} ^www\.mediamaticstudio\.com$ [NC]
RewriteRule ^ https://mediamaticstudio.com%{REQUEST_URI} [L,R=301]

# MIME Types & Headers for Production Stability
<IfModule mod_mime.c>
  AddType application/javascript .js
  AddType application/javascript .mjs
</IfModule>

<IfModule mod_headers.c>
  # Ensure JS modules can be loaded cross-origin (needed for some LiteSpeed configs)
  <FilesMatch "\.(js|mjs|css|json|woff|woff2|ttf|otf)$">
    Header set Access-Control-Allow-Origin "*"
  </FilesMatch>
  
  # Ensure caches are handled correctly when compression is used
  Header append Vary Accept-Encoding
</IfModule>


# Redirect index.html to / (avoid duplicate content)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /index\.html\ HTTP/
RewriteRule ^index\.html$ / [R=301,L]

# Force trailing slash for all URLs (except files)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_URI} !/$
RewriteCond %{REQUEST_URI} !^/index\.html$
RewriteRule ^(.*)$ /$1/ [L,R=301]

# Handle SPA Routing (React)
# 1. Skip paths that are real files or directories
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 2. Skip any requests starting with assets/ or having common file extensions
# This prevents 404 assets from being served as index.html (which causes JS errors)
RewriteCond %{REQUEST_URI} ^/assets/ [OR]
RewriteCond %{REQUEST_URI} \.(js|css|ico|png|jpg|jpeg|gif|svg|webp|woff|woff2|ttf|otf|mp4|webm|wav|mp3|m4a|aac|oga)$ [NC]
RewriteRule ^ - [L]

# 3. Everything else goes to index.html
RewriteRule ^ index.html [L]


